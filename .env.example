# RingCentral API
RC_CLIENT_ID=your_client_id
RC_CLIENT_SECRET=your_client_secret
RC_JWT_TOKEN=your_jwt_token
RC_SERVER=https://platform.ringcentral.com

# Anthropic (Claude) API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Unsplash (free tier: 50 requests/hour)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Auth0 (for dashboard login)
AUTH0_DOMAIN=your_auth0_domain
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
FLASK_SECRET=generate_a_random_secret_key

# Cron secret (protects the /api/cron/run endpoint)
CRON_SECRET=generate_a_random_cron_secret

# WordPress (legacy — per-site creds now in SQLite sites table)
WP_SITE_URL=https://eudaimoniahomes.com
WP_USERNAME=your_wordpress_username
WP_APP_PASSWORD=your_application_password
